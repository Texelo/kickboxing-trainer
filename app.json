{
  "expo": {
    "name": "kickboxing-trainer",
    "slug": "kickboxing-trainer",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "kickboxingtrainer",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jack.hulme.kickboxingtrainer",
      "infoPlist": {
        "CFBundleDocumentTypes": [
          {
            "CFBundleTypeName": "Kickboxing Workout",
            "LSItemContentTypes": ["com.jack.hulme.kickboxingtrainer.kbx"],
            "LSHandlerRank": "Owner"
          }
        ],
        "UTExportedTypeDeclarations": [
          {
            "UTTypeIdentifier": "com.jack.hulme.kickboxingtrainer.kbx",
            "UTTypeTagSpecification": {
              "public.filename-extension": ["kbx"]
            },
            "UTTypeDescription": "Kickboxing Workout",
            "UTTypeConformsTo": ["public.data"]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.jack.hulme.kickboxingtrainer",
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            { "scheme": "content", "host": "*", "mimeType": "*/*", "pathPattern": ".*\\.kbx" },
            { "scheme": "file", "host": "*", "mimeType": "*/*", "pathPattern": ".*\\.kbx" }
          ],
          "category": ["DEFAULT", "BROWSABLE"]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "baseUrl": "/kickboxing-trainer"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "67c41a16-107a-4baa-b47d-7856789cdee7"
      }
    }
  }
}
